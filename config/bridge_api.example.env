# Bridge API token mapping. Keep real tokens out of version control.
BRIDGE_TOKEN_HERMES=replace-me-hermes
BRIDGE_TOKEN_JARVY=replace-me-jarvy
BRIDGE_TOKEN_JORDAN=replace-me-jordan

# Optional immediate notify hooks. Point each agent at its local bridge_intake_watch.py --listen endpoint.
# The API will POST to these URLs for handoff lifecycle events (create, close, block) and fall back to polling if delivery fails.
BRIDGE_NOTIFY_URL_HERMES=http://127.0.0.1:8521/notify
BRIDGE_NOTIFY_URL_JARVY=http://127.0.0.1:8522/notify
BRIDGE_NOTIFY_URL_JORDAN=http://127.0.0.1:8523/notify

# Optional lifecycle event consumer commands.
# bridge_intake_watch.py will execute these read-only hooks for sender-side lifecycle events
# like handoff_closed and handoff_blocked. Each command receives the raw JSON event on stdin.
# BRIDGE_NOTIFY_EVENT_COMMAND_HERMES=
# BRIDGE_NOTIFY_EVENT_COMMAND_JARVY=
# BRIDGE_NOTIFY_EVENT_COMMAND_JORDAN=

# Optional launch settings for scripts/bridge_api_server.py
BRIDGE_API_HOST=127.0.0.1
BRIDGE_API_PORT=8427
BRIDGE_ROOT=/home/caragon/agent-shared/bridge
BRIDGE_API_CONFIG=/home/caragon/agent-shared/config/bridge_api.env

# Optional patrol tuning (can also be passed as CLI flags to bridge_patrol.py)
# Built-in active unresolved alert: warn after this many hours if a handoff is still active
# and only has placeholder/admin summary text (for example `pending` or `actively investigating`).
# BRIDGE_PATROL_ACTIVE_ALERT_HOURS=0.5
# BRIDGE_PATROL_REMINDER_AFTER_HOURS=0.5
# BRIDGE_PATROL_REMINDER_REPEAT_HOURS=2
# BRIDGE_PATROL_ESCALATE_AFTER_HOURS=6
# BRIDGE_PATROL_ESCALATE_REPEAT_HOURS=24
